{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "PORT",
        "API_CORS_ORIGINS",
        "DATABASE_URL",
        "NEXT_PUBLIC_API_URL",
        "API_URL",
        "NEXT_PUBLIC_SITE_URL_FR",
        "NEXT_PUBLIC_SITE_URL_EN",
        "NEXT_PUBLIC_ASSETS_BASE_URL",
        "EXPO_PUBLIC_API_URL"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "generate:openapi": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "openapi.json"],
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "TEST_DATABASE_URL", "CI"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "env": [
        "PORT",
        "API_CORS_ORIGINS",
        "NEXT_PUBLIC_API_URL",
        "API_URL",
        "NEXT_PUBLIC_SITE_URL_FR",
        "NEXT_PUBLIC_SITE_URL_EN",
        "NEXT_PUBLIC_ASSETS_BASE_URL",
        "EXPO_PUBLIC_API_URL"
      ],
      "cache": false,
      "persistent": true
    }
  }
}
