{
  "name": "@ffc/api-client",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "generate:client": "openapi-typescript ../../apps/api/openapi.json -o src/generated/schema.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.14.1"
  },
  "devDependencies": {
    "@ffc/eslint-config": "workspace:*",
    "eslint": "^9.36.0",
    "openapi-typescript": "^7.9.1",
    "typescript": "^5.9.3"
  }
}
