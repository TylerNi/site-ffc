# Environnement d'exécution : development | test | production
NODE_ENV=development

# Port HTTP de l'API
PORT=4000

# Origines autorisées (CORS), séparées par des virgules
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# PostgreSQL (local : docker compose up -d postgres — voir docker-compose.yml)
DATABASE_URL=postgresql://ffc:ffc@localhost:5432/ffc_dev?schema=public

# Base de données jetable utilisée par les tests d'intégration (vitest).
# Créée automatiquement par le globalSetup si absente.
TEST_DATABASE_URL=postgresql://ffc:ffc@localhost:5432/ffc_test?schema=public

# ------------------------------------------------------------------
# Authentification (tâche 05) — les valeurs par défaut de développement
# sont REFUSÉES en production (voir src/config/env.ts).
# ------------------------------------------------------------------

# Secret HMAC des access tokens JWT (>= 32 caractères aléatoires).
# Générer : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# JWT_ACCESS_SECRET=

# Durées de vie des jetons (défauts : 900 s = 15 min ; 30 jours).
# JWT_ACCESS_TTL_SECONDS=900
# REFRESH_TOKEN_TTL_DAYS=30

# Clé AES-256-GCM des secrets TOTP — 32 octets en base64.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# APP_ENCRYPTION_KEY=

# URL de la vitrine web (liens des courriels de vérification/réinitialisation).
APP_WEB_URL=http://localhost:3000

# Domaine du cookie de refresh en production (ex. .filtrationmontreal.com).
# AUTH_COOKIE_DOMAIN=

# Proxys de confiance devant l'API (Cloudflare + ALB = 2 en production, 0 en local).
TRUST_PROXY_HOPS=0

# Connexions sociales — client IDs acceptés comme audience des ID tokens.
# Google : client IDs OAuth (web + iOS + Android), séparés par des virgules.
# GOOGLE_CLIENT_IDS=
# Apple : Services ID (web) et bundle IDs (iOS), séparés par des virgules.
# APPLE_CLIENT_IDS=

# Courriels transactionnels : log (console, dev/test) | ses (AWS SES, production).
MAIL_DRIVER=log
MAIL_FROM=Filtration Montréal <no-reply@filtrationmontreal.com>
AWS_REGION=ca-central-1

# ------------------------------------------------------------------
# Import du catalogue BigCommerce (tâche 08) — jetons API admin des deux
# vitrines (checklist d'accès de la tâche 01). Lecture seule.
# ------------------------------------------------------------------
BIGCOMMERCE_DOMAIN_EN=furnacefilterscanada.com
BIGCOMMERCE_DOMAIN_FR=filtrationmontreal.com
# BIGCOMMERCE_STORE_HASH_EN=
# BIGCOMMERCE_ACCESS_TOKEN_EN=
# BIGCOMMERCE_STORE_HASH_FR=
# BIGCOMMERCE_ACCESS_TOKEN_FR=

# Bucket S3 des images produit (tâche 03 — infra Terraform).
# S3_BUCKET_PRODUCT_IMAGES=product-images
