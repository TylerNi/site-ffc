  "info": {
    "title": "FFC API",
    "description": "API de la plateforme Filtration Montréal / Furnace Filters Canada",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "service": {
            "type": "string",
            "example": "ffc-api"
          },
          "version": {
            "type": "string",
            "example": "0.1.0"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "uptimeSeconds": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "status",
          "service",
          "version",
          "timestamp",
          "uptimeSeconds"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "marie@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 10,
            "maxLength": 128
          },
          "firstName": {
            "type": "string",
            "example": "Marie"
          },
          "lastName": {
            "type": "string",
            "example": "Tremblay"
          },
          "locale": {
            "type": "string",
            "enum": [
              "fr",
              "en"
            ],
            "default": "fr"
          },
          "guestCartToken": {
            "type": "string",
            "description": "Jeton de panier invité à fusionner dans le compte"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "MessageResponseDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": [
          "message"
        ]
      },
      "VerifyEmailDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Jeton reçu par courriel"
          }
        },
        "required": [
          "token"
        ]
      },
      "EmailOnlyDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "marie@example.com"
          }
        },
        "required": [
          "email"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "marie@example.com"
          },
          "password": {
            "type": "string"
          },
          "guestCartToken": {
            "type": "string",
            "description": "Jeton de panier invité à fusionner à la connexion"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "enum": [
              "CUSTOMER",
              "STAFF",
              "ADMIN"
            ]
          },
          "locale": {
            "type": "string",
            "enum": [
              "fr",
              "en"
            ]
          },
          "emailVerified": {
            "type": "boolean"
          },
          "mfaEnabled": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "email",
          "firstName",
          "lastName",
          "role",
          "locale",
          "emailVerified",
          "mfaEnabled",
          "createdAt"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "mfaRequired": {
            "type": "boolean",
            "description": "true = fournir un code via POST /auth/login/mfa"
          },
          "challengeToken": {
            "type": "string",
            "description": "Présent si mfaRequired — valide 5 minutes"
          },
          "accessToken": {
            "type": "string",
            "description": "JWT Bearer de 15 minutes"
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh token opaque (aussi posé en cookie httpOnly pour le web)"
          },
          "tokenType": {
            "type": "string",
            "enum": [
              "Bearer"
            ]
          },
          "expiresIn": {
            "type": "number",
            "description": "Durée de vie de l’access token (secondes)"
          },
          "user": {
            "$ref": "#/components/schemas/UserProfileDto"
          }
        },
        "required": [
          "mfaRequired"
        ]
      },
      "MfaLoginDto": {
        "type": "object",
        "properties": {
          "challengeToken": {
            "type": "string",
            "description": "Jeton de défi retourné par POST /auth/login (mfaRequired=true)"
          },
          "code": {
            "type": "string",
            "description": "Code TOTP à 6 chiffres ou code de secours XXXXX-XXXXX"
          },
