# Environnement de TEST (vitest) — chargé à la place de .env (voir
# ConfigModule dans src/app.module.ts). AUCUN secret ici : ce fichier est
# versionné. Les valeurs pointent la base jetable ffc_test ; les helpers de
# test (test/auth-helpers.ts) ajustent le reste via process.env.
NODE_ENV=test
DATABASE_URL=postgresql://ffc:ffc@localhost:5432/ffc_test?schema=public
TEST_DATABASE_URL=postgresql://ffc:ffc@localhost:5432/ffc_test?schema=public
