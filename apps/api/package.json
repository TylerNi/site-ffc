{
  "name": "@ffc/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "generate:openapi": "nest build && node dist/scripts/generate-openapi.js",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:erd": "prisma generate && tsx scripts/generate-erd.ts",
    "bigcommerce:export": "tsx scripts/bigcommerce/export.ts",
    "bigcommerce:import": "tsx scripts/bigcommerce/import.ts",
    "bigcommerce:crawl": "tsx scripts/bigcommerce/crawl-urls.ts",
    "bigcommerce:redirects": "tsx scripts/bigcommerce/redirects.ts",
    "ai:bench": "tsx --env-file-if-exists=.env scripts/ai-bench.ts"
  },
  "prisma": {
    "seed": "pnpm exec tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/client-sesv2": "^3.1079.0",
    "@aws-sdk/s3-presigned-post": "3.1079.0",
    "@ffc/core": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "bullmq": "^5.63.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.9.3",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "openai": "^6.46.0",
    "otpauth": "^9.5.1",
    "pdfkit": "^0.19.1",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.35.3",
    "stripe": "^19.3.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@ffc/eslint-config": "workspace:*",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.27",
    "@swc/core": "^1.15.43",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.36.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.2.6"
  }
}
