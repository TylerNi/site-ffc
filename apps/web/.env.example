# URL de base de l'API NestJS (client : autocomplétion; serveur : repli).
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL de l'API vue du serveur Next (SSR/ISR). Repli : NEXT_PUBLIC_API_URL.
# Utile quand le serveur joint l'API par le réseau interne (ECS, Docker).
# API_URL=http://localhost:4000

# Origines publiques par locale — canonical, hreflang, sitemaps, robots.
# Sans ces valeurs (dev) : http://localhost:3000 pour les deux locales,
# le français sous le préfixe /fr. En production :
# NEXT_PUBLIC_SITE_URL_FR=https://filtrationmontreal.com
# NEXT_PUBLIC_SITE_URL_EN=https://furnacefilterscanada.com

# CDN des images produit (tâche 08). Sans valeur : placeholders SVG.
# NEXT_PUBLIC_ASSETS_BASE_URL=https://cdn.filtrationmontreal.com
